# ==============================================================================
# TEMPLATE KONFIGURASI CHATOPS BOT (DOKUMENTASI DEVOPS)
# Salin berkas ini ke '.env' dan sesuaikan nilainya dengan server Anda.
# ==============================================================================

# 1. TOKEN TELEGRAM BOT
# Dapatkan token bot resmi dari Telegram BotFather (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZ-abcdefg

# 2. KONFIGURASI AI ENGINE (OLLAMA LOKAL)
# Tentukan URL host Ollama lokal Anda. Default port Ollama adalah 11434.
OLLAMA_HOST=http://localhost:11434

# 3. GUARDRAIL KEAMANAN: DAFTAR USER YANG DIIZINKAN (AUTHENTICATION)
# Pisahkan dengan tanda koma (,) jika ada lebih dari satu ID.
# Ini mencegah pihak luar/tidak dikenal mengontrol server Anda via Telegram.
# Contoh mendapatkan ID Anda: kirim pesan '/start' ke bot ini setelah aktif.
ALLOWED_TELEGRAM_IDS=8393907559,123456789

# 4. ALAMAT ALERT NOTIFIKASI DUA ARAH (SERVER-TO-USER)
# Chat ID tujuan untuk notifikasi ketika kontainer Docker mengalami error/mati (die/oom).
# Biasanya diisi dengan ID Telegram pribadi Anda atau ID Grup Telegram DevOps.
ALERT_CHAT_ID=8393907559
